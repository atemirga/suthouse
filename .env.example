DATABASE_URL="postgresql://user:password@localhost:5432/suthouse_finance?schema=public"

ODATA_URL="https://YOUR-1C-HOST/odata/standard.odata"
ODATA_LOGIN="odata.user"
ODATA_PASSWORD="changeme"

NODE_TLS_REJECT_UNAUTHORIZED="0"

SYNC_INTERVAL_MINUTES="15"
SYNC_DAYS_BACK="60"

TIMEZONE="Asia/Almaty"

# Auth (single admin)
ADMIN_USER="admin"
# scrypt: <salt-hex>:<key-hex>, сгенерировать:
# node -e "const c=require('crypto');const s=c.randomBytes(16).toString('hex');console.log(s+':'+c.scryptSync('YOUR_PASSWORD',s,64).toString('hex'))"
ADMIN_PASSWORD_HASH="REPLACE_ME"
# случайные 32 байта в hex: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="REPLACE_ME"
SESSION_DAYS="14"
